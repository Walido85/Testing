---
interface Props {
	title?: string;
	description?: string;
	lang?: string;
	pageName?: string;
	initialData?: any;
	[key: string]: any;
}

const { 
	title = "TuniWave - Your portal for Tunisian Radio, TV, News and Sports in real-time.", 
	description = "TuniWave - Your portal for Tunisian Radio, TV, News and Sports in real-time.",
	lang = "ar",
	pageName = "Home",
	initialData = null,
	...rest
} = Astro.props;

import '@/index.css';
import AppShell from '@/components/AppShell';
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
	<head>
		<script is:inline>
			(function() {
				const savedTheme = localStorage.getItem('theme');
				const theme = savedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				if (document.documentElement) {
					document.documentElement.setAttribute('data-theme', theme);
					if (theme === 'dark') document.documentElement.classList.add('dark');
					else document.documentElement.classList.remove('dark');
				}
			})();
			
			// Register astro:after-swap ONCE only — is:inline re-runs on every swap,
			// so without this guard we'd accumulate duplicate listeners.
			if (!window.__themeListenerRegistered) {
				window.__themeListenerRegistered = true;
				document.addEventListener('astro:after-swap', () => {
					const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
					if (document.documentElement) {
						document.documentElement.setAttribute('data-theme', theme);
						if (theme === 'dark') document.documentElement.classList.add('dark');
						else document.documentElement.classList.remove('dark');
					}
				});
			}
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
		<meta name="theme-color" content="#fc3c44" />
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="mobile-web-app-capable" content="yes">
		<meta name="description" content={description} />
		<meta name="keywords" content="Tunisia, Radio, TV, News, Sports, TuniWave, Live, Football" />
		<meta name="author" content="TuniWave" />
		<meta name="robots" content="index, follow" />
		<link rel="manifest" href="/manifest.json" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<link rel="dns-prefetch" href="https://fonts.googleapis.com">
		<link rel="dns-prefetch" href="https://fonts.gstatic.com">
		<link rel="dns-prefetch" href="https://www.googletagmanager.com">
		<link rel="dns-prefetch" href="https://pagead2.googlesyndication.com">
		<link rel="dns-prefetch" href="https://firestore.googleapis.com">
		<link rel="dns-prefetch" href="https://identitytoolkit.googleapis.com">
		<link rel="dns-prefetch" href="https://www.google-analytics.com">

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" />
		<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" media="print" onload="this.removeAttribute('media')" />
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		</noscript>

		<meta name="google-adsense-account" content="ca-pub-5565782072443281">
		<title>{title}</title>
		<script is:inline>
			// Trailing slash redirect
			if (!window.__trailingSlashChecked) {
				window.__trailingSlashChecked = true;
				(function() {
					const path = window.location.pathname;
					if (path.length > 1 && !path.endsWith('/') && !path.split('/').pop().includes('.')) {
						window.location.replace(path + '/' + window.location.search + window.location.hash);
					}
				})();
			}

			// Diagnostic Error Catcher
			window.addEventListener('error', function(event) {
				const div = document.createElement('div');
				div.style.position = 'fixed';
				div.style.top = '10px'; div.style.left = '10px'; div.style.right = '10px';
				div.style.padding = '15px'; div.style.backgroundColor = 'rgba(255,0,0,0.9)';
				div.style.color = 'white'; div.style.zIndex = '999999';
				div.innerHTML = '<strong>CRASH (Error):</strong><br/>' + event.message;
				if (document.body) {
					document.body.appendChild(div);
				}
			});
			window.addEventListener('unhandledrejection', function(event) {
				const div = document.createElement('div');
				div.style.position = 'fixed';
				div.style.top = '80px'; div.style.left = '10px'; div.style.right = '10px';
				div.style.padding = '15px'; div.style.backgroundColor = 'rgba(200,0,0,0.9)';
				div.style.color = 'white'; div.style.zIndex = '999999';
				div.innerHTML = '<strong>CRASH (Promise):</strong><br/>' + (event.reason && event.reason.message ? event.reason.message : event.reason);
				if (document.body) {
					document.body.appendChild(div);
				}
			});
		</script>
	</head>
	<body>
		<AppShell client:only="react" pageName={pageName} initialData={initialData} lang={lang} url={Astro.url.pathname} {...rest} />

		<script is:inline>
			// Register Service Worker
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js')
						.then(() => console.log('SW registered'))
						.catch(err => console.log('SW registration failed:', err));
				});
			}
		</script>
		
		<script is:inline>
			(function() {
				var scriptsLoaded = false;
				function loadDeferredScripts() {
					if (scriptsLoaded) return;
					scriptsLoaded = true;
					
					setTimeout(function() {
						var gtagScript = document.createElement('script');
						gtagScript.src = "https://www.googletagmanager.com/gtag/js?id=G-732S890757";
						gtagScript.async = true;
						document.head.appendChild(gtagScript);
						window.dataLayer = window.dataLayer || [];
						function gtag(){dataLayer.push(arguments);}
						gtag('js', new Date());
						gtag('config', 'G-732S890757', { send_page_view: true });
					}, 10);

					setTimeout(function() {
						var script = document.createElement('script');
						script.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5565782072443281";
						script.crossOrigin = "anonymous";
						script.async = true;
						document.head.appendChild(script);
					}, 100);

					events.forEach(function(e) { window.removeEventListener(e, loadDeferredScripts); });
				}

				var events = ['scroll', 'mousemove', 'touchstart', 'click', 'keydown'];
				events.forEach(function(e) { window.addEventListener(e, loadDeferredScripts, {once: true, passive: true}); });
				
				window.addEventListener('load', function() {
					setTimeout(loadDeferredScripts, 8000);
				});
			})();
		</script>
	</body>
</html>


