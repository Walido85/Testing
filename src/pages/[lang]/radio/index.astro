---
import Layout from '@/layouts/Layout.astro';
import { db } from '@/firebase';
import { collection, query, where, getDocs } from 'firebase/firestore';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang } = Astro.params;

// Fetch stations at build time for instant loading
let radioData = [];
try {
  const q = query(
    collection(db, "stations"),
    where("status", "==", "active")
  );
  const snapshot = await getDocs(q);
  radioData = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
} catch (e) {
  console.error("Radio Portal Build Error:", e);
}
---

<Layout title="TuniWave - Radio" lang={lang} pageName="RadioPortal" initialData={radioData} />
