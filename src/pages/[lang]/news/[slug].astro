---
import Layout from '@/layouts/Layout.astro';
import { db } from '@/firebase';
import { collection, query, where, getDocs, limit, doc, getDoc, orderBy } from 'firebase/firestore';

export async function getStaticPaths() {
  const languages = ['en', 'fr', 'ar'];
  
  // 1. Fetch ALL active sources once
  const sourcesQuery = query(collection(db, 'rss'), where('status', '==', 'active'));
  const sourcesSnapshot = await getDocs(sourcesQuery);
  const sources = sourcesSnapshot.docs.map(doc => ({
    id: doc.id,
    language: (doc.data().language || doc.data().Language || 'ar').toLowerCase()
  }));

  const paths = [];

  for (const lang of languages) {
    // 2. Filter sources for THIS language
    const langSources = sources.filter(s => {
      if (lang === 'ar') return s.language.startsWith('ar') || s.language.includes('arabic');
      if (lang === 'en') return s.language.startsWith('en') || s.language.includes('english');
      if (lang === 'fr') return s.language.startsWith('fr') || s.language.includes('french');
      return s.language.startsWith(lang);
    }).map(s => s.id);

    if (langSources.length > 0) {
      // 3. Fetch latest 400 articles for THIS language's active sources
      // (Reduced from 1000 to keep build fast and stay within free tier limits across 3 languages)
      const articlesQuery = query(
        collection(db, 'rss_articles'),
        where('sourceId', 'in', langSources.slice(0, 30)), // Firestore 'in' limit is 30
        orderBy('pubDate', 'desc'),
        limit(400)
      );
      const snapshot = await getDocs(articlesQuery);
      
      snapshot.docs.forEach(doc => {
        const data = doc.data();
        paths.push({ 
          params: { lang, slug: data.slug || doc.id } 
        });
      });
    }
  }

  return paths;
}

const { lang, slug } = Astro.params;

// Fetch article data at build time for instant loading
let articleData = null;
try {
  const decodedSlug = slug ? decodeURIComponent(slug) : '';
  
  // Try finding by slug first
  let newsQuery = query(
    collection(db, 'rss_articles'),
    where('slug', '==', decodedSlug),
    limit(1)
  );
  let snapshot = await getDocs(newsQuery);
  
  if (snapshot.empty && slug) {
    newsQuery = query(collection(db, 'rss_articles'), where('slug', '==', slug), limit(1));
    snapshot = await getDocs(newsQuery);
  }

  let docSnapshot = null;
  if (!snapshot.empty) {
    docSnapshot = snapshot.docs[0];
  } else if (slug) {
    // Fallback to ID
    const docRef = doc(db, 'rss_articles', slug);
    const idSnapshot = await getDoc(docRef);
    if (idSnapshot.exists()) docSnapshot = idSnapshot;
  }

  if (docSnapshot) {
    const rawData = docSnapshot.data();
    articleData = {
      id: docSnapshot.id,
      ...rawData,
      thumbnail: rawData.imageUrl || rawData.thumbnail || null,
      pubDate: rawData.pubDate?.seconds ? rawData.pubDate.seconds * 1000 : (typeof rawData.pubDate === 'number' ? rawData.pubDate : new Date(rawData.pubDate).getTime())
    };
  }
} catch (e) {
  console.error("SSR Fetch Error:", e);
}

const title = articleData ? `${articleData.title} - TuniWave News` : "TuniWave - Article";
const description = articleData ? articleData.description : "Latest news from Tunisia";
---

<Layout 
  title={title} 
  description={description} 
  lang={lang}
  pageName="ArticleDetail"
  initialData={articleData}
/>
