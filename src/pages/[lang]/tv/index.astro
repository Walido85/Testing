---
import Layout from '@/layouts/Layout.astro';
import AstroPageLoader from '@/components/AstroPageLoader';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang } = Astro.params;
---

<Layout title="TuniWave - Live TV" lang={lang} pageName="LiveTV" />
