---
// Redirect root to the appropriate language
---
<script is:inline>
  (function() {
    var savedLang = localStorage.getItem('i18nextLng');
    var matches = document.cookie.match(/i18nextLng=(ar|fr|en)/);
    if (!savedLang && matches && matches[1]) {
      savedLang = matches[1];
    }
    var navLang = (navigator.language || '').split('-')[0];
    var target = savedLang && ['ar', 'fr', 'en'].includes(savedLang) ? savedLang : 
                 (['ar', 'fr', 'en'].includes(navLang) ? navLang : 'ar');
    window.location.replace('/' + target + '/' + window.location.search + window.location.hash);
  })();
</script>
