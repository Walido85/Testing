---
import Layout from '@/layouts/Layout.astro';
import AstroPageLoader from '@/components/AstroPageLoader';

// This page acts as a dynamic fallback for links that aren't pre-rendered yet.
// It will detect the URL and try to load the content via the React island.
---

<Layout title="TuniWave - Page Not Found">
  <div id="dynamic-fallback-container" style="display: none;">
    <div class="min-h-[70vh] flex flex-col items-center justify-center px-4 text-center">
      <div class="w-24 h-24 bg-red-500/10 rounded-full flex items-center justify-center mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-500"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <h1 class="text-4xl font-black mb-4">404 - Page Not Found</h1>
      <p class="text-lg opacity-60 mb-8 max-w-md">The page you are looking for doesn't exist or has been moved.</p>
      <a href="/" class="px-8 py-3 bg-[var(--accent-color)] text-white rounded-full font-bold hover:scale-105 transition-transform">
        Return Home
      </a>
    </div>
  </div>
  <div id="dynamic-loader-hidden" style="display: none;">
    <AstroPageLoader client:only="react" />
  </div>
</Layout>

<script>
  // Smart 404 handler: Fix trailing slashes and locale issues
  (function() {
    const path = window.location.pathname;
    
    // 1. If path is missing trailing slash, try to add it (except for files)
    if (path.length > 1 && !path.endsWith('/') && !path.split('/').pop().includes('.')) {
      window.location.replace(path + '/' + window.location.search + window.location.hash);
      return;
    }

    // 2. Try to hydrate if it looks like a valid route
    // Only show the 404 UI if hydration fails or it's a known bad path
    const container = document.getElementById('dynamic-fallback-container');
    const loader = document.getElementById('dynamic-loader-hidden');
    
    if (path.includes('/news/') || path.includes('/sports/') || path.includes('/tv/')) {
       if (loader) {
         loader.style.display = 'block';
       }
    } else {
       if (container) {
         container.style.display = 'block';
       }
    }

    console.log('404 Fallback: Handling path', path);
  })();
</script>
